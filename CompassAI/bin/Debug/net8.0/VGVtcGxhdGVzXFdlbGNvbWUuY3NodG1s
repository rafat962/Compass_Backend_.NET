@model dynamic
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; }
        .container { width: 80%; margin: 20px auto; padding: 20px; border: 1px solid #ddd; border-radius: 10px; background-color: #f9f9f9; }
        .header { text-align: center; color: #2c3e50; }
        .btn { display: inline-block; padding: 10px 20px; margin-top: 20px; color: #fff; background-color: #3498db; text-decoration: none; border-radius: 5px; }
        .footer { margin-top: 30px; font-size: 0.8em; color: #777; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <h2 class="header">أهلاً بك في GeoPlatform!</h2>
        <p>عزيزي <strong>@Model.UserName</strong>,</p>
        <p>تم تفعيل حسابك بنجاح. نحن سعداء جداً بانضمامك إلينا في المنصة.</p>
        <p>يمكنك الآن البدء في استكشاف كافة المميزات المتاحة لك.</p>
        <div style="text-align: center;">
            <a href="@Model.LoginUrl" class="btn" style="color: white !important;">تسجيل الدخول الآن</a>
        </div>
        <div class="footer">
            <p>هذا إيميل تلقائي، يرجى عدم الرد عليه.</p>
            <p>&copy; @DateTime.Now.Year GeoPlatform Team</p>
        </div>
    </div>
</body>
</html>